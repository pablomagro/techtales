<% if (page.current === 1 && page.posts.first()) { %>
  <script>window.location.replace('<%= url_for(page.posts.first().path) %>');</script>
  <noscript><meta http-equiv="refresh" content="0;url=<%= url_for(page.posts.first().path) %>"></noscript>
<% } else { %>
  <%- partial('_partial/archive', {pagination: 2, index: true}) %>
<% } %>