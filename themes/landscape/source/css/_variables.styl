// Config
support-for-ie = false
vendor-prefixes = webkit moz ms official

// Colors
color-default = #1a1a1a
color-grey = #999
color-border = #e0e0e0
color-link = #2563eb
color-background = #f0f0f0
color-sidebar-text = #888
color-widget-background = #e8e8e8
color-widget-border = #ddd
color-footer-background = #e8e8e8
color-mobile-nav-background = #191919
color-twitter = #00aced
color-facebook = #3b5998
color-pinterest = #cb2027
color-google = #dd4b39

// Fonts
font-sans = "Inter", "Helvetica Neue", Helvetica, Arial, sans-serif
font-serif = Georgia, "Times New Roman", serif
font-mono = "Source Code Pro", Consolas, Monaco, Menlo, Consolas, monospace
font-icon = FontAwesome
font-icon-path = "fonts/fontawesome-webfont"
font-icon-version = "4.0.3"
font-size = 16px
line-height = 1.6em
line-height-title = 1.1em

// Header
logo-size = 40px
subtitle-size = 16px
banner-height = 64px
// banner-url = "images/banner.jpg"
banner-url = "images/banner_code.jpg"

sidebar = hexo-config("sidebar")

// Layout
// Changed 13/09/2016
// block-margin = 50px
block-margin = 30px
article-padding = 20px
mobile-nav-width = 280px
main-column = 9
sidebar-column = 3
// Added 13/09/2016
code-border-radius = 6px

if sidebar and sidebar isnt bottom
  _sidebar-column = sidebar-column
else
  _sidebar-column = 0

// Grids
column-width = 80px
gutter-width = 20px
columns = main-column + _sidebar-column

// Media queries
mq-mobile = "screen and (max-width: 479px)"
mq-tablet = "screen and (min-width: 480px) and (max-width: 767px)"
mq-normal = "screen and (min-width: 768px)"
