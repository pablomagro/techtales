header-bar-height = 56px

#header
  height: header-bar-height
  background: #111
  position: relative
  overflow: hidden

#header-outer
  height: header-bar-height
  position: relative

#banner
  display: none

#header-title
  position: absolute
  top: 0
  left: 50%
  transform: translateX(-50%)
  height: header-bar-height
  display: flex
  align-items: center
  float: none
  width: auto

#logo-wrap
  margin: 0
  padding: 0
  font-size: 1em

#logo
  text-decoration: none
  color: #fff
  font-weight: 700
  font-size: 1em
  letter-spacing: -0.01em

#subtitle
  display: none

#subtitle-wrap
  display: none

#header-inner
  position: absolute
  top: 0
  left: 0
  right: 0
  height: header-bar-height
  display: flex
  align-items: center
  float: none
  width: auto

#main-nav
  display: flex
  align-items: center
  height: header-bar-height
  margin: 0

$nav-link
  color: rgba(255, 255, 255, 0.55)
  text-decoration: none
  text-shadow: none
  transition: color 0.2s
  display: flex
  align-items: center
  height: header-bar-height
  padding: 0 14px
  float: none
  &:hover
    color: #fff

.nav-icon
  @extend $nav-link
  font-family: font-icon
  font-size: 14px
  cursor: pointer

.main-nav-link
  @extend $nav-link
  font-size: 0.85em
  font-weight: 400
  letter-spacing: 0.5px
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  &:before
    content: "\f0c9"
  @media mq-mobile
    display: flex

#sub-nav
  display: flex
  align-items: center
  height: header-bar-height
  margin-left: auto

#nav-rss-link
  &:before
    content: "\f09e"

#nav-search-btn
  &:before
    content: "\f002"

#search-form-wrap
  position: absolute
  top: 15px
  width: 150px
  height: 30px
  right: -150px
  opacity: 0
  transition: 0.2s ease-out
  &.on
    opacity: 1
    right: 0
  @media mq-mobile
    width: 100%
    right: -100%

.search-form
  position: absolute
  top: 0
  left: 0
  right: 0
  background: #fff
  padding: 5px 15px
  border-radius: 15px
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.3)

.search-form-input
  border: none
  background: none
  color: color-default
  width: 100%
  font: 13px font-sans
  outline: none
  &::-webkit-search-results-decoration
  &::-webkit-search-cancel-button
    -webkit-appearance: none

.search-form-submit
  position: absolute
  top: 50%
  right: 10px
  margin-top: -7px
  font: 13px font-icon
  border: none
  background: none
  color: #bbb
  cursor: pointer
  &:hover, &:focus
    color: #777
